[Unit]
Description=CodeInsight Daily Ingestion Timer
Requires=codeinsight-daily-ingestion.service

[Timer]
# Run every 5 minutes; the script decides if it's time based on DB config
OnCalendar=*:0/5
# Randomize within 60 seconds to avoid thundering herd
RandomizedDelaySec=60
Persistent=true

[Install]
WantedBy=timers.target
