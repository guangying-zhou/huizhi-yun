[Unit]
Description=CodeInsight Commit Sync Coordinator
After=network.target

[Service]
Type=oneshot
User=codeinsight
WorkingDirectory=/srv/codeinsight
Environment=DB_HOST=127.0.0.1
Environment=DB_USER=root
Environment=DB_NAME=codeinsightdb
ExecStart=/usr/bin/env python3 /srv/codeinsight/server/scripts/commit_sync_coordinator.py --run-now
TimeoutStartSec=1h

[Install]
WantedBy=multi-user.target
