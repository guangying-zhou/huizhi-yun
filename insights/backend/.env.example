# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user_prod
DB_PASSWORD=your_db_password_prod
DB_NAME=repoinsightdb
# SVN Configuration (if using SVN on this server)
SVN_ROOT_PATH=/path/to/svn/repos
SVN_MAX_DIFF_BYTES=524288
# GitLab Configuration
GITLAB_URL=http://gitlab.example.com
GITLAB_TOKEN=your_production_token
# Python Service
LOG_LEVEL=INFO
PYTHONPATH=/opt/repoinsight/backend
PYTHON_BIN=/opt/repoinsight/backend/.venv/bin/python
