{
  "name": "platform",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build --dotenv .env",
    "build:prod": "nuxt build --dotenv .env.prod",
    "build:dev": "nuxt build --dotenv .env.dev",
    "build:cloudflare": "nuxt build --preset=cloudflare_module",
    "db:init-dev": "node scripts/init-platform-dev-db.mjs",
    "db:init-dev:wiztek": "bash deploy/mysql/init-hzy-platform-dev.sh",
    "db:verify-dev": "node scripts/verify-platform-dev-db.mjs",
    "deploy:cloudflare": "node scripts/assert-cloudflare-deploy-allowed.mjs && pnpm run build:cloudflare && pnpm dlx wrangler@4 deploy --config wrangler.jsonc",
    "dev": "VITE_HMR_PORT=24681 nuxt dev --dotenv .env.dev --port 3011",
    "signing:key": "node scripts/generate-platform-signing-key.mjs",
    "pm2:delete": "pm2 delete ${HZY_PLATFORM_PM2_NAME:-hzy-platform-prod}",
    "pm2:delete:dev": "pm2 delete hzy-platform-dev",
    "pm2:delete:prod": "pm2 delete hzy-platform-prod",
    "pm2:logs": "pm2 logs ${HZY_PLATFORM_PM2_NAME:-hzy-platform-prod}",
    "pm2:logs:dev": "pm2 logs hzy-platform-dev",
    "pm2:logs:prod": "pm2 logs hzy-platform-prod",
    "pm2:start": "mkdir -p logs && pm2 startOrReload ecosystem.config.cjs --update-env",
    "pm2:start:dev": "HZY_PLATFORM_ENV_FILE=.env.dev pnpm run pm2:start",
    "pm2:start:prod": "HZY_PLATFORM_ENV_FILE=.env.prod pnpm run pm2:start",
    "pm2:status": "pm2 status ${HZY_PLATFORM_PM2_NAME:-hzy-platform-prod}",
    "pm2:status:dev": "pm2 status hzy-platform-dev",
    "pm2:status:prod": "pm2 status hzy-platform-prod",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck",
    "test": "node --test --experimental-strip-types \"test/**/*.test.ts\""
  },
  "dependencies": {
    "@hzy/authz-core": "workspace:*",
    "@iconify-json/lucide": "^1.2.71",
    "@iconify-json/simple-icons": "^1.2.55",
    "@nuxt/ui": "^4.1.0",
    "@pinia/nuxt": "^0.11.3",
    "@vueuse/nuxt": "^13.9.0",
    "date-fns": "^4.1.0",
    "mysql2": "^3.15.3",
    "nuxt": "^4.2.0",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.9.0",
    "@types/node": "^24.10.0",
    "eslint": "^9.38.0",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.1.2"
  },
  "packageManager": "pnpm@10.32.1"
}
