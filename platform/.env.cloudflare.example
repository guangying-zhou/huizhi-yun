# Legacy / exception-only Cloudflare deploy variables.
# Wiztek platform-prod/platform-dev must run on domestic PM2/Nginx for fixed-IP
# WeCom login. `pnpm run deploy:cloudflare` is blocked unless
# HZY_ALLOW_PLATFORM_CLOUDFLARE_DEPLOY=true is set explicitly.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Cloudflare Worker secrets. Set these with:
# pnpm dlx wrangler@4 secret put <NAME> --config wrangler.jsonc
GITLAB_BOT_TOKEN=
# Recommended first-party internal token for Platform, Tenant Gateway and Console.
HZY_CLOUDFLARE_INTERNAL_TOKEN=
# Legacy compatibility only; keep blank when HZY_CLOUDFLARE_INTERNAL_TOKEN is set.
PLATFORM_INTERNAL_SERVICE_TOKENS=
PLATFORM_OPS_UIDS=
PLATFORM_BOOTSTRAP_OPS_UIDS=
HZY_PLATFORM_SIGNING_PRIVATE_KEY=
HZY_PLATFORM_DIAGNOSTICS_TOKEN=
RESEND_API_KEY=
PLATFORM_AUTH_EMAIL_FROM=
GOOGLE_OAUTH_CLIENT_SECRET=
WECOM_CORPSECRET=

# Cloudflare Worker vars are defined in wrangler.jsonc.
# Update PLATFORM_SERVICE_URL and the custom domain before production deploy.
PLATFORM_SERVICE_URL=https://hzy.isme.dev
NUXT_PUBLIC_GOOGLE_ADMIN_LOGIN_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_REDIRECT_URI=https://hzy.isme.dev/api/platform/auth/google/callback
GOOGLE_OAUTH_HOSTED_DOMAIN=
GOOGLE_OAUTH_ALLOWED_EMAILS=
GOOGLE_OAUTH_ALLOWED_DOMAINS=
NUXT_PUBLIC_WECOM_ADMIN_LOGIN_ENABLED=false
WECOM_CORPID=
WECOM_AGENTID=
WECOM_OAUTH_REDIRECT_URI=https://hzy.isme.dev/api/platform/auth/wecom/callback
WECOM_OAUTH_ALLOWED_USERIDS=
WECOM_OAUTH_ALLOW_ALL=false
