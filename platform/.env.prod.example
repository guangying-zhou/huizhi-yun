# platform-prod on domestic PM2/Nginx.
# Production DB keeps the canonical name hzy_platform.

NODE_ENV=production
HZY_PLATFORM_PM2_NAME=hzy-platform-prod
HOST=127.0.0.1
PORT=3010

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=platform_app
DB_PASSWORD=
DB_NAME=hzy_platform
DB_CONNECTION_LIMIT=10

PLATFORM_SERVICE_URL=https://platform.wiztek.cn
NUXT_PUBLIC_APP_DISPLAY_NAME=汇智云平台
NUXT_PUBLIC_PLATFORM_STAGE=production
HZY_DEPLOYMENT_PROFILE=platform-self-hosted-db
NUXT_PUBLIC_DEPLOYMENT_PROFILE=platform-self-hosted-db

PLATFORM_AUTH_DEV_MOCK=false
PLATFORM_AUTH_SESSION_TTL_SECONDS=28800
PLATFORM_OPS_UIDS=
PLATFORM_BOOTSTRAP_OPS_UIDS=
PLATFORM_ENABLE_OPS_RBAC=true
PLATFORM_ALLOW_OPS_UID_FALLBACK=false
PLATFORM_ALLOW_LEGACY_ADMIN_API=false
# Recommended first-party internal token for Platform, Tenant Gateway and Console.
HZY_CLOUDFLARE_INTERNAL_TOKEN=
# Legacy compatibility only; keep blank when HZY_CLOUDFLARE_INTERNAL_TOKEN is set.
PLATFORM_INTERNAL_SERVICE_TOKENS=
HZY_PLATFORM_DIAGNOSTICS_TOKEN=

RESEND_API_KEY=
PLATFORM_AUTH_EMAIL_FROM=no-reply@wiztek.cn
PLATFORM_AUTH_ACTIVATION_BASE_URL=https://platform.wiztek.cn
PLATFORM_AUTH_EMAIL_ACTIVATION_TTL_SECONDS=86400

NUXT_PUBLIC_GOOGLE_ADMIN_LOGIN_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://platform.wiztek.cn/api/platform/auth/google/callback
GOOGLE_OAUTH_HOSTED_DOMAIN=
GOOGLE_OAUTH_ALLOWED_EMAILS=
GOOGLE_OAUTH_ALLOWED_DOMAINS=

NUXT_PUBLIC_WECOM_ADMIN_LOGIN_ENABLED=true
WECOM_CORPID=
WECOM_AGENTID=
WECOM_CORPSECRET=
WECOM_OAUTH_REDIRECT_URI=https://platform.wiztek.cn/api/platform/auth/wecom/callback
WECOM_OAUTH_ALLOWED_USERIDS=
WECOM_OAUTH_ALLOW_ALL=false

# Required in production. Use a different key from platform-dev.
HZY_PLATFORM_SIGNING_PRIVATE_KEY=base64:<prod-ed25519-pkcs8-private-pem>
PLATFORM_SIGNING_KEY_DIR=

GITLAB_BASE_URL=
GITLAB_BOT_TOKEN=
GITLAB_DEFAULT_APP_MANIFEST_PATH=app.manifest.json
GITLAB_REQUEST_TIMEOUT_MS=15000

HZY_OBSERVABILITY_API_URL=
HZY_OBSERVABILITY_ADMIN_TOKEN=
