# Codocs Cloudflare Worker public/non-secret values.
# Real codocs/.env.cloudflare must stay local and ignored.

HZY_DEPLOYMENT_PROFILE=managed-cloud-agent
HZY_CODOCS_WORKER_NAME=hzy-codocs
HZY_CODOCS_WORKERS_DEV=true

# Optional route binding for staging gray release.
HZY_CODOCS_ROUTE_PATTERN=
HZY_CODOCS_ZONE_NAME=

# Tenant runtime / data runtime endpoint. Secrets stay in Worker secrets.
HZY_TENANT_RUNTIME_URL=
HZY_TENANT_RUNTIME_AUDIENCE=data-runtime
HZY_TENANT_RUNTIME_TENANT=
HZY_TENANT_RUNTIME_DEPLOYMENT=

HZY_OBJECT_STORAGE_PROVIDER=aliyun-oss-s3
HZY_OBJECT_STORAGE_FORCE_PATH_STYLE=
NUXT_PUBLIC_COLLABORATION_URL=
