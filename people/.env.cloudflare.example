# People Cloudflare Worker public/non-secret values.
# Copy to .env.cloudflare.local for local deployment settings.

HZY_DEPLOYMENT_PROFILE=managed-cloud-agent
HZY_PEOPLE_WORKER_NAME=hzy-people
HZY_PEOPLE_WORKERS_DEV=true

# Optional route binding for Worker origin or staging gray release.
HZY_PEOPLE_ROUTE_PATTERN=
HZY_PEOPLE_ZONE_NAME=

HZY_APP_BASE_PATH=/people/

# Tenant runtime / data runtime endpoint. Secrets stay in Worker secrets or are
# injected by Tenant Gateway request headers.
HZY_DATA_ACCESS_MODE=tenant-runtime
HZY_PEOPLE_DATA_ACCESS_MODE=tenant-runtime
HZY_TENANT_RUNTIME_URL=
HZY_TENANT_RUNTIME_AUDIENCE=data-runtime
HZY_TENANT_RUNTIME_TENANT=
HZY_TENANT_RUNTIME_DEPLOYMENT=

# Shared managed cloud defaults to https://console.huizhi.yun when unset.
HZY_CONSOLE_URL=
