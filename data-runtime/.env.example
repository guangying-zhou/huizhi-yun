HZY_DATA_RUNTIME_HOST=0.0.0.0
HZY_DATA_RUNTIME_PORT=18080
HZY_DATA_RUNTIME_TENANT=demo
HZY_DATA_RUNTIME_DEPLOYMENT=demo-agent

HZY_DATA_RUNTIME_DB_HOST=127.0.0.1
HZY_DATA_RUNTIME_DB_PORT=3306
HZY_DATA_RUNTIME_DB_USER=cf_app
HZY_DATA_RUNTIME_DB_PASSWORD=
HZY_DATA_RUNTIME_DB_CONNECTION_LIMIT=5

# Legacy OA/WizBiz source database for controlled one-off/incremental imports.
# Do not set these in Cloudflare Workers or module Nuxt apps.
HZY_WIZBIZ_DB_HOST=127.0.0.1
HZY_WIZBIZ_DB_PORT=3306
HZY_WIZBIZ_DB_USER=
HZY_WIZBIZ_DB_PASSWORD=
HZY_WIZBIZ_DB_NAME=wizbizdb
HZY_WIZBIZ_DB_CONNECTION_LIMIT=3

# disabled is only for local development. Use static_token for the first tunnel POC
# or jwt with JWKS for production enrollment.
HZY_DATA_RUNTIME_AUTH_MODE=static_token
HZY_DATA_RUNTIME_STATIC_TOKEN=platform-provided-token
HZY_DATA_RUNTIME_JWT_AUDIENCE=data-runtime
# HZY_DATA_RUNTIME_JWKS_URL=https://console.example.com/oauth/jwks
# HZY_DATA_RUNTIME_JWKS_JSON='{"keys":[...]}'

HZY_FINANCE_AGENT_ENABLED=true
HZY_FINANCE_DB_NAME=hzy_finance

# Workflow is disabled by default until the tenant opts into Agent-covered
# workflow runtime endpoints.
HZY_WORKFLOW_AGENT_ENABLED=false
HZY_WORKFLOW_DB_NAME=hzy_workflow

# WebDev metadata is disabled by default. Enable only for the WebDev control
# plane metadata database; WebDev Workers must access it through /v1/webdev/*.
HZY_WEBDEV_AGENT_ENABLED=false
HZY_WEBDEV_DB_NAME=hzy_webdev

# Tenant-runtime compatibility adapters. Keep disabled until the corresponding
# Nuxt app is configured with an app-specific tenant-runtime endpoint.
HZY_ASSETS_AGENT_ENABLED=false
HZY_ASSETS_DB_NAME=hzy_assets

HZY_PEOPLE_AGENT_ENABLED=false
HZY_PEOPLE_DB_NAME=hzy_people

HZY_ALTOC_AGENT_ENABLED=false
HZY_ALTOC_DB_NAME=hzy_altoc

HZY_AIMS_AGENT_ENABLED=false
HZY_AIMS_DB_NAME=hzy_aims

HZY_CODOCS_AGENT_ENABLED=false
HZY_CODOCS_DB_NAME=hzy_codocs
