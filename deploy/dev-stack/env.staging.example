# Public browser entry for this staging tenant. Use the tenant domain when
# testing the SaaS shape; dev-stack derives Console SSO callback URLs from this.
HZY_DEPLOYMENT_PUBLIC_URL=https://wiztek.huizhi.yun
HZY_PLATFORM_URL=https://huizhi.yun
# Public Console origin exposed to browsers and OIDC clients.
HZY_MANAGED_CONSOLE_URL=https://wiztek.huizhi.yun
# Server-to-server Console runtime API origin. Business Workers should not call
# back through the Tenant Gateway host for runtime config subrequests.
HZY_CONSOLE_RUNTIME_API_URL=https://console.huizhi.yun
# Additional origin hosts that can reach Nuxt dev servers through Tenant Gateway
# or reverse proxies. The tenant host is derived from HZY_DEPLOYMENT_PUBLIC_URL.
HZY_DEV_STACK_ALLOWED_HOSTS=hzy.wiztek.cn

# Required on staging. Do not inherit module .env.dev DB_* values on a shared
# server; those files are usually local developer defaults.
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_CONNECTION_LIMIT=5
# Set DB_SSL=true when the MySQL user requires SSL/TLS.
DB_SSL=
# Optional PEM CA. Keep it on one line and escape line breaks as \n.
DB_SSL_CA=
DB_SSL_REJECT_UNAUTHORIZED=true
# Leave DB_NAME empty unless every app intentionally uses the same schema.
DB_NAME=

# Default keeps the staging dev stack light. Add apps as needed, for example:
# HZY_DEV_STACK_APPS=console,workflow,codocs,aims

# Console activation. Values must match the deployment generated in Platform.
HZY_PLATFORM_TENANT_CODE=C000001
HZY_PLATFORM_DEPLOYMENT_CODE=C000001-console
HZY_PLATFORM_RUNTIME_TOKEN=
HZY_PLATFORM_SIGNING_KID=
# Keep the PEM on one line and escape line breaks as \n.
HZY_PLATFORM_SIGNING_PUBKEY=

# Required by Console vault encryption if not already provided by console/.env.dev.
HZY_CONSOLE_VAULT_MASTER_KEY=

# Optional upstream SSO override. If omitted, dev-stack derives callback URLs
# from HZY_DEPLOYMENT_PUBLIC_URL.
SSO_OIDC_CLIENT_ID=
SSO_OIDC_CLIENT_SECRET=
SSO_OIDC_REDIRECT_URI=
SSO_OIDC_POST_LOGOUT_REDIRECT_URI=
