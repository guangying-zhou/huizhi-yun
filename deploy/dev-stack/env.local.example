# Local dev-stack defaults.
# Copy to env.local and override sensitive values if needed.

HZY_DEPLOYMENT_PUBLIC_URL=http://localhost:3180
HZY_CONSOLE_URL=http://localhost:3180
HZY_CONSOLE_API_URL=http://localhost:3180
HZY_WORKFLOW_API_URL=http://127.0.0.1:3105

HZY_AUTH_MODE=console
HZY_CONSOLE_RUNTIME_ENABLED=true
HZY_DIRECTORY_PROVIDER=console
HZY_LEGACY_AUTH_BRIDGE=false

# Default keeps the dev stack light. Add apps as needed, for example:
# HZY_DEV_STACK_APPS=console,workflow,codocs,aims

# Leave DB values empty to use each app's .env.dev. Fill them only when you
# want the whole stack to use one local database server.
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_CONNECTION_LIMIT=

CONSOLE_COLLAB_MODE=embedded
COLLAB_PORT=3107
COLLAB_ADDRESS=127.0.0.1
COLLAB_DB_HOST=
COLLAB_DB_PORT=
COLLAB_DB_USER=
COLLAB_DB_PASSWORD=
COLLAB_DB_NAME=
COLLABORATION_AUTH_SECRET=

# Leave platform activation values empty to use console/.env.dev locally.
HZY_PLATFORM_URL=
HZY_PLATFORM_TENANT_CODE=
HZY_PLATFORM_DEPLOYMENT_CODE=
HZY_PLATFORM_RUNTIME_TOKEN=
HZY_PLATFORM_SIGNING_KID=
HZY_PLATFORM_SIGNING_PUBKEY=
HZY_PLATFORM_LICENSE_TOKEN=
HZY_PLATFORM_BUNDLE_CACHE_DIR=

HZY_CONSOLE_VAULT_MASTER_KEY=
HZY_DEV_STACK_GIT_PULL=false
HZY_DEV_STACK_RUN_TYPECHECK=false
