{
  "name": "collab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "deploy:cloudflare:poc": "pnpm dlx wrangler@4 deploy --config wrangler.codocs-poc.jsonc",
    "preview:cloudflare:poc": "pnpm dlx wrangler@4 dev --config wrangler.codocs-poc.jsonc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hocuspocus/common": "^3.4.4",
    "@hocuspocus/extension-redis": "^3.4.3",
    "@hocuspocus/server": "^3.4.3",
    "ali-oss": "^6.23.0",
    "dotenv": "^16.4.7",
    "ioredis": "^5.5.0",
    "y-prosemirror": "^1.3.3",
    "yjs": "^13.6.25"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.23.1",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0"
  },
  "packageManager": "pnpm@10.32.1"
}
