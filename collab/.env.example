# Collab Runtime
COLLAB_APP_CODE=collab
COLLAB_PORT=3021
COLLAB_ADDRESS=127.0.0.1
COLLAB_PROVIDER=hocuspocus
COLLAB_PUBLIC_BASE_PATH=/collab/
COLLAB_RUNTIME_MODE=standalone
COLLAB_STOP_ON_SIGNALS=true

# Console-managed runtime placeholders. Standalone mode keeps these optional.
HZY_CONSOLE_API_URL=http://localhost:3000
HZY_PLATFORM_LICENSE_PATH=./license.lic

# Codocs data source used by the current Hocuspocus provider.
# In Console embedded mode, prefer COLLAB_DB_* so Console DB_* can continue to point at hzy_console.
COLLAB_DB_HOST=127.0.0.1
COLLAB_DB_PORT=3306
COLLAB_DB_USER=root
COLLAB_DB_PASSWORD=
COLLAB_DB_NAME=hzy_codocs
COLLAB_DB_CONNECTION_LIMIT=10

# Redis is optional in local development.
COLLAB_REDIS_DISABLED=false
COLLAB_REDIS_HOST=127.0.0.1
COLLAB_REDIS_PORT=6379
COLLAB_REDIS_PASSWORD=
COLLAB_REDIS_CONNECT_TIMEOUT=3000

# OSS persistence.
# Console embedded mode resolves these from Console oss.default by default.
# Standalone mode may still use these envs directly during migration or isolated deployment.
COLLAB_OSS_INTEGRATION_CODE=oss.default
COLLAB_OSS_BUCKET_NAME=
COLLAB_OSS_ENDPOINT=
COLLAB_OSS_ACCESS_KEY_ID=
COLLAB_OSS_ACCESS_KEY_SECRET=
COLLAB_OSS_REGION=
COLLAB_OSS_BUCKET_DOMAIN=
COLLAB_OSS_PROJECTS_BUCKET_NAME=
COLLAB_OSS_PROJECTS_ENDPOINT=
COLLAB_OSS_PROJECTS_BUCKET_DOMAIN=
COLLAB_OSS_IMAGES_BUCKET_NAME=
COLLAB_OSS_IMAGES_ENDPOINT=
COLLAB_OSS_IMAGES_BUCKET_DOMAIN=
COLLAB_OSS_RECYCLE_DAYS=30

# Must match the short-lived collaboration token signer used by Codocs.
COLLABORATION_AUTH_SECRET=
