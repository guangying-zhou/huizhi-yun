HZY_DEPLOYMENT_PROFILE=managed-cloud-agent
HZY_WEBDEV_WORKER_NAME=hzy-webdev

# Worker origin route. Tenant users should enter through <tenant>.huizhi.yun/webdev/.
HZY_WEBDEV_ROUTE_PATTERN=webdev.huizhi.yun/*
HZY_WEBDEV_ZONE_NAME=huizhi.yun

# Tenant-facing URL used for OIDC callback and app links.
HZY_DEPLOYMENT_PUBLIC_URL=https://wiztek.huizhi.yun
HZY_APP_BASE_PATH=/webdev/

# WebDev is sensitive. Keep app grant required in Cloudflare deployments.
HZY_WEBDEV_REQUIRE_APP_GRANT=true
# Optional bootstrap allowlist before Platform imports webdev/app.manifest.json.
# HZY_WEBDEV_ALLOWED_UIDS=zhouguangying

# Non-secret endpoints. Tokens must be Cloudflare secrets.
HZY_WEBDEV_DEV_AGENT_URL=https://dev-agent-1.huizhi.yun
HZY_WEBDEV_DATA_RUNTIME_URL=https://wiztek-data-runtime.huizhi.yun
