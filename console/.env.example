# Local console-dev defaults.
# Production and shared test deployments should copy .env.prod.example or
# .env.test.example instead. This file is intentionally safe for local Nuxt dev:
# it does not register a Platform deployment, heartbeat, refresh bundles on
# boot, materialize auth clients, start background jobs, or start embedded Collab.
# User-initiated writes still go to DB_NAME.

# Platform activation
HZY_CONSOLE_RUN_MODE=dev
HZY_CONSOLE_TRUST_TENANT_GATEWAY=false
HZY_PLATFORM_RUNTIME_ENABLED=false
HZY_PLATFORM_URL=http://localhost:3011
HZY_PLATFORM_TENANT_CODE=
HZY_PLATFORM_DEPLOYMENT_CODE=
HZY_PLATFORM_RUNTIME_TOKEN=
HZY_PLATFORM_SIGNING_KID=
HZY_PLATFORM_SIGNING_PUBKEY=
HZY_PLATFORM_LICENSE_TOKEN=
HZY_PLATFORM_LICENSE_PATH=
HZY_PLATFORM_BUNDLE_CACHE_BACKEND=file
HZY_PLATFORM_BUNDLE_CACHE_DIR=.data/platform-runtime-dev
HZY_PLATFORM_BUNDLE_CACHE_SCOPE=
HZY_PLATFORM_BUNDLE_CACHE_LEGACY_FALLBACK=false
HZY_PLATFORM_HEARTBEAT_INTERVAL_MS=300000
HZY_PLATFORM_HEARTBEAT_ENABLED=false
HZY_PLATFORM_BUNDLE_REFRESH_ON_BOOT=false
HZY_PLATFORM_AUTH_CLIENT_MATERIALIZE=false
HZY_CONSOLE_AUTH_CLIENT_MATERIALIZE_MODE=append
HZY_CONSOLE_BACKGROUND_JOBS_ENABLED=false
HZY_CONSOLE_DEV_POLICY_BYPASS=true
HZY_DEV_APPLICATIONS=
HZY_CONSOLE_DEV_APPLICATIONS=
HZY_CONSOLE_DIAGNOSTICS_TOKEN=
CONSOLE_COLLAB_MODE=disabled
CONSOLE_AUTH_SIGNING_KEY_AUTOGENERATE=false
CONSOLE_AUTH_SIGNING_KEY_ROTATE_UNUSABLE=false
CONSOLE_AUTH_SIGNING_PRIVATE_JWK=
CONSOLE_AUTH_SIMULATION_SECRET=

# Public URL
NUXT_PUBLIC_SITE_URL=

# Console upstream login provider. Business apps still consume Console OIDC;
# these settings only control how Console authenticates employees upstream.
SSO_OIDC_ENABLE=true
SSO_OIDC_PROVIDER_CODE=sso_oidc
SSO_OIDC_ISSUER=https://sso.wiztek.cn
SSO_OIDC_CLIENT_ID=
SSO_OIDC_CLIENT_SECRET=
SSO_OIDC_REDIRECT_URI=
SSO_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/api/auth/oidc-post-logout
SSO_OIDC_SCOPE="openid profile email"

CAS_ENABLE=false
CAS_BASE_URL=
CAS_SERVICE_URL=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=hzy_console

# Account API
HZY_ACCOUNT_API_URL=http://localhost:3000
HZY_ACCOUNT_API_KEY=
HZY_ACCOUNT_API_SECRET=

# Workflow API
HZY_WORKFLOW_API_URL=http://localhost:3009

# Codocs API
HZY_CODOCS_API_URL=http://localhost:3001

# Public app metadata
NUXT_PUBLIC_APP_DISPLAY_NAME=企业控制台
NUXT_PUBLIC_APP_LOGO=/logo.svg

# WeCom OAuth
WECOM_CORPID=
WECOM_CORPSECRET=
WECOM_AGENTID=

# Notification test mode
NOTIFY_REDIRECT_TO=

# Notification Runtime
HZY_NOTIFICATION_RUNTIME_PACKAGE_BASE_URL=https://downloads.huizhi.yun/packages/hzy-notification-runtime
HZY_NOTIFICATION_RUNTIME_CLIENT_ID=notification-runtime

# Console vault local encryption key for storageBackend=db_encrypted.
# Use at least 32 random bytes encoded as base64 or hex in real deployments.
HZY_CONSOLE_VAULT_MASTER_KEY=

# Optional local service clients for cross-module server calls.
# Console materializes these into service_clients/service_client_credentials on startup.
HZY_SERVICE_CLIENT_AIMS_CLIENT_ID=aims.runtime
HZY_SERVICE_CLIENT_AIMS_CLIENT_CODE=aims.runtime
HZY_SERVICE_CLIENT_AIMS_SECRET=
HZY_SERVICE_CLIENT_AIMS_GRANTS=workflow:proxy,workflow:action_defs:sync,workflow:instances:read,codocs:documents:read,codocs:documents:write,assets:read,assets:write,altoc:write,altoc:receivable:mark-billable,altoc:service_ticket:delivery-result:sync,system_settings:view,integration_config:view,credential_vault:resolve,notifications:publish,notification-runtime:send

HZY_SERVICE_CLIENT_FINANCE_CLIENT_ID=finance.runtime
HZY_SERVICE_CLIENT_FINANCE_CLIENT_CODE=finance.runtime
HZY_SERVICE_CLIENT_FINANCE_SECRET=
HZY_SERVICE_CLIENT_FINANCE_GRANTS=assets:read,altoc:read,altoc:write,altoc:contract:finance-summary:sync,system_settings:view,integration_config:view,credential_vault:resolve,notifications:publish,notification-runtime:send

HZY_SERVICE_CLIENT_CODOCS_CLIENT_ID=codocs.runtime
HZY_SERVICE_CLIENT_CODOCS_CLIENT_CODE=codocs.runtime
HZY_SERVICE_CLIENT_CODOCS_SECRET=
HZY_SERVICE_CLIENT_CODOCS_GRANTS=workflow:proxy,workflow:action_defs:sync,system_settings:view,integration_config:view,credential_vault:resolve,notifications:publish,notification-runtime:send

HZY_SERVICE_CLIENT_WORKFLOW_CLIENT_ID=workflow.runtime
HZY_SERVICE_CLIENT_WORKFLOW_CLIENT_CODE=workflow.runtime
HZY_SERVICE_CLIENT_WORKFLOW_SECRET=
HZY_SERVICE_CLIENT_WORKFLOW_GRANTS=data-runtime:workflow:read,data-runtime:workflow:write,tenant-runtime:workflow:read,tenant-runtime:workflow:write,system_settings:view,notifications:publish,notification-runtime:send

HZY_SERVICE_CLIENT_NOTIFICATION_RUNTIME_CLIENT_ID=notification-runtime
HZY_SERVICE_CLIENT_NOTIFICATION_RUNTIME_CLIENT_CODE=notification-runtime
HZY_SERVICE_CLIENT_NOTIFICATION_RUNTIME_SECRET=
HZY_SERVICE_CLIENT_NOTIFICATION_RUNTIME_GRANTS=integration_config:view,credential_vault:resolve
