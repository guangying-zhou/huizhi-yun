        "console:console_overview:view",
        "console:org_profile:view",
        "console:directory_users:admin",
        "console:directory_departments:admin",
        "console:directory_projects:admin",
        "console:directory_sources:admin",
        "console:directory_sync:admin"
      ]
    },
    {
      "code": "console:security_admin",
      "name": "安全管理员",
      "description": "管理集成、凭证库、服务凭证和安全相关系统参数",
      "suggestedPermissions": [
        "console:console_overview:view",
        "console:system_settings:admin",
        "console:integration_config:admin",
        "console:credential_vault:admin",
        "console:service_clients:admin",
        "console:collab_runtime:admin"
