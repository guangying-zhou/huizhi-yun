# Shared console-test runtime.
# This instance is the only shared integration / end-to-end Console runtime.

NODE_ENV=production
HZY_CONSOLE_PM2_NAME=hzy-console-test
HOST=127.0.0.1
PORT=3031
HZY_CONSOLE_RUN_MODE=test
HZY_CONSOLE_TRUST_TENANT_GATEWAY=false
HZY_PLATFORM_RUNTIME_ENABLED=true
HZY_PLATFORM_HEARTBEAT_ENABLED=true
HZY_PLATFORM_BUNDLE_REFRESH_ON_BOOT=true
HZY_PLATFORM_AUTH_CLIENT_MATERIALIZE=true
HZY_CONSOLE_AUTH_CLIENT_MATERIALIZE_MODE=append
HZY_CONSOLE_BACKGROUND_JOBS_ENABLED=true
HZY_CONSOLE_DEV_POLICY_BYPASS=false
CONSOLE_COLLAB_MODE=disabled
CONSOLE_AUTH_SIGNING_KEY_AUTOGENERATE=false
CONSOLE_AUTH_SIGNING_KEY_ROTATE_UNUSABLE=false

# Platform dev control plane
HZY_PLATFORM_URL=https://platform-dev.wiztek.cn
HZY_PLATFORM_TENANT_CODE=wiztek
HZY_PLATFORM_DEPLOYMENT_CODE=wiztek-test-console
HZY_PLATFORM_RUNTIME_TOKEN=
HZY_PLATFORM_SIGNING_KID=
HZY_PLATFORM_SIGNING_PUBKEY=
HZY_PLATFORM_LICENSE_TOKEN=
HZY_PLATFORM_BUNDLE_CACHE_BACKEND=file
HZY_PLATFORM_BUNDLE_CACHE_DIR=.data/platform-runtime-test
HZY_PLATFORM_BUNDLE_CACHE_SCOPE=wiztek-test-console
HZY_PLATFORM_BUNDLE_CACHE_LEGACY_FALLBACK=false
HZY_PLATFORM_HEARTBEAT_INTERVAL_MS=300000
HZY_CONSOLE_DIAGNOSTICS_TOKEN=

# Shared Console OIDC signing key. Use the same managed key material as
# console-prod unless auth runtime is moved to an isolated DB.
CONSOLE_AUTH_SIGNING_PRIVATE_JWK=
CONSOLE_AUTH_SIMULATION_SECRET=

# Shared Console DB
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=hzy_console

# Public URL
NUXT_PUBLIC_SITE_URL=https://hzy-test.wiztek.cn
HZY_DEPLOYMENT_PUBLIC_URL=https://hzy-test.wiztek.cn

# Console upstream login provider
SSO_OIDC_ENABLE=true
SSO_OIDC_PROVIDER_CODE=sso_oidc
SSO_OIDC_ISSUER=https://sso.wiztek.cn
SSO_OIDC_CLIENT_ID=
SSO_OIDC_CLIENT_SECRET=
SSO_OIDC_REDIRECT_URI=https://hzy-test.wiztek.cn/api/auth/oidc-callback
SSO_OIDC_POST_LOGOUT_REDIRECT_URI=https://hzy-test.wiztek.cn/api/auth/oidc-post-logout
SSO_OIDC_SCOPE="openid profile email"

CAS_ENABLE=false
CAS_BASE_URL=
CAS_SERVICE_URL=

# Workflow API
HZY_WORKFLOW_API_URL=http://localhost:3020

# Codocs API
HZY_CODOCS_API_URL=http://localhost:3001

# Public app metadata
NUXT_PUBLIC_APP_DISPLAY_NAME=企业控制台测试环境
NUXT_PUBLIC_APP_LOGO=/logo.svg

# WeCom OAuth
WECOM_CORPID=
WECOM_CORPSECRET=
WECOM_AGENTID=

# Notification test mode
NOTIFY_REDIRECT_TO=

# Notification Runtime
HZY_NOTIFICATION_RUNTIME_PACKAGE_BASE_URL=https://downloads.huizhi.yun/packages/hzy-notification-runtime
HZY_NOTIFICATION_RUNTIME_CLIENT_ID=notification-runtime

# Console vault local encryption key for storageBackend=db_encrypted.
HZY_CONSOLE_VAULT_MASTER_KEY=

# Optional local service clients for cross-module server calls.
HZY_SERVICE_CLIENT_AIMS_CLIENT_ID=aims.runtime
HZY_SERVICE_CLIENT_AIMS_CLIENT_CODE=aims.runtime
HZY_SERVICE_CLIENT_AIMS_SECRET=
HZY_SERVICE_CLIENT_AIMS_GRANTS=workflow:proxy,workflow:action_defs:sync,workflow:instances:read,codocs:documents:read,codocs:documents:write,system_settings:view,integration_config:view,credential_vault:resolve,notifications:publish,notification-runtime:send

HZY_SERVICE_CLIENT_CODOCS_CLIENT_ID=codocs.runtime
HZY_SERVICE_CLIENT_CODOCS_CLIENT_CODE=codocs.runtime
HZY_SERVICE_CLIENT_CODOCS_SECRET=
HZY_SERVICE_CLIENT_CODOCS_GRANTS=workflow:proxy,workflow:action_defs:sync,system_settings:view,integration_config:view,credential_vault:resolve,notifications:publish,notification-runtime:send

HZY_SERVICE_CLIENT_WORKFLOW_CLIENT_ID=workflow.runtime
HZY_SERVICE_CLIENT_WORKFLOW_CLIENT_CODE=workflow.runtime
HZY_SERVICE_CLIENT_WORKFLOW_SECRET=
HZY_SERVICE_CLIENT_WORKFLOW_GRANTS=data-runtime:workflow:read,data-runtime:workflow:write,tenant-runtime:workflow:read,tenant-runtime:workflow:write,system_settings:view,notifications:publish,notification-runtime:send

HZY_SERVICE_CLIENT_NOTIFICATION_RUNTIME_CLIENT_ID=notification-runtime
HZY_SERVICE_CLIENT_NOTIFICATION_RUNTIME_CLIENT_CODE=notification-runtime
HZY_SERVICE_CLIENT_NOTIFICATION_RUNTIME_SECRET=
HZY_SERVICE_CLIENT_NOTIFICATION_RUNTIME_GRANTS=integration_config:view,credential_vault:resolve
